# ============================================================
# Dockerized LGSM Rust Dedicated Server - Environment Config
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# Do NOT commit .env - it is listed in .gitignore.
# ============================================================

# LinuxGSM version to use. See releases at:
# https://github.com/GameServerManagers/LinuxGSM/releases
LINUX_GSM_VERSION=v20.4.1

# RCON network interface binding.
# 127.0.0.1 exposes RCON only on localhost (recommended).
# Set to 0.0.0.0 to expose publicly (use with SSH tunnel or VPN only).
RUST_RCON_INTERFACE=127.0.0.1

# Host UID/GID for volume file ownership (linuxserver-style).
# Run `id` on your host to find these values.
PUID=1000
PGID=1000

# ---- SERVER BOOT SETTINGS ----
# Settings take effect every time the server boots.

#SERVER_MAXPLAYERS=50
#SERVER_HOSTNAME=Rust

# Uncomment to enable EAC (Easy Anti-Cheat).
# Linux clients cannot connect when EAC is enabled.
#ENABLE_RUST_EAC=1

# ---- GENERATED MAP SETTINGS ----

# range: 1-2147483647. Reproduce a specific procedural map.
# Default: random seed. Changing this generates a new map on next boot.
#SERVER_SEED=1

# Used to recover a known salt from an existing map.
#SERVER_SALT=

# Map size in meters. range: 1000-6000. Default: 3000.
#SERVER_WORLDSIZE=3000

# ---- CUSTOM MAP SETTINGS ----
# If a custom map is set, generated map settings above are ignored.

# Public base URL where clients will download your self-hosted map.
#MAP_BASE_URL=http://localhost:8000/

# URL to a publicly hosted custom map (e.g. Dropbox link).
# Overrides MAP_BASE_URL unless SELF_HOST_CUSTOM_MAP=true.
#CUSTOM_MAP_URL=https://example.com/some-map.map

# Download CUSTOM_MAP_URL locally and self-host it.
# Set to true to force self-hosting.
#SELF_HOST_CUSTOM_MAP=false

# ---- PLUGINS ----
# Oxide plugins to install from uMod. Merged with mod-configs/plugins.txt.
# Use KEY="value" syntax (no colon). Multiline: wrap in double quotes,
# one plugin per line, no leading spaces.
#
#PLUGIN_LIST="TruePve
#ZoneManager
#ZoneManagerAutoZones"

# ---- ADVANCED SETTINGS ----

# Monitor RustDedicated and kill the container if it stops,
# triggering a docker compose auto-restart.
uptime_monitoring=true

# Enable verbose debug output from apply-settings.sh.
#apply_settings_debug_mode=false
