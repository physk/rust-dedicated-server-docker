# ============================================================
# Dockerized Rust Dedicated Server - Environment Config
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# Do NOT commit .env - it is listed in .gitignore.
# ============================================================

# ---- DOCKER / HOST SETTINGS ----

# Host UID/GID for volume file ownership.
# Run `id` on your host to find your values.
PUID=1000
PGID=1000

# Network interface the RCON port is exposed on.
# 127.0.0.1 = localhost only (recommended).
# 0.0.0.0   = all interfaces (use only with SSH tunnel or VPN).
RUST_RCON_INTERFACE=127.0.0.1

# ---- SERVER IDENTITY ----

# Name shown in the Rust server browser.
#SERVER_HOSTNAME=Rust

# Folder name used for save data under serverfiles/server/.
# Changing this is like starting a fresh server (old saves stay on disk).
#SERVER_IDENTITY=rustserver

# ---- NETWORK ----

# IP address the game server process binds to. 0.0.0.0 = all interfaces.
#SERVER_IP=0.0.0.0

# UDP port clients connect to. Must match the port mapping in docker-compose.yml.
#SERVER_PORT=28015

# TCP port for RCON connections. Must match RUST_RCON_INTERFACE port above.
#RCON_PORT=28016

# ---- PLAYERS ----

# Maximum number of players allowed on the server at once.
#SERVER_MAXPLAYERS=50

# ---- SAVE SETTINGS ----

# How often (in seconds) the server saves the map and player data.
#SERVER_SAVEINTERVAL=300

# ---- PROCEDURAL MAP SETTINGS ----
# Ignored when a custom map is configured below.

# Map generation seed. Range: 1-2147483647.
# Omit (or leave blank) to get a different random map each wipe.
# Set a fixed value to reproduce the same map layout.
#SERVER_SEED=

# Map salt. Paired with seed to uniquely identify a saved map.
# Leave blank unless restoring a specific known map.
#SERVER_SALT=

# Map size in meters. Range: 1000-6000. Larger = more RAM + generation time.
#SERVER_WORLDSIZE=3000

# ---- CUSTOM MAP SETTINGS ----

# Direct URL to a hosted .map file (e.g. Dropbox, Cloudflare R2).
# When set, procedural map settings above are ignored.
#CUSTOM_MAP_URL=https://example.com/your-map.map

# Serve a .map file placed in the custom-maps/ directory via a built-in HTTP
# server on port 8000. Set to true and drop your .map file in custom-maps/.
#SELF_HOST_CUSTOM_MAP=false

# Base URL used when SELF_HOST_CUSTOM_MAP=true.
# Clients must be able to reach this address to download the map.
#MAP_BASE_URL=http://your-server-ip:8000

# ---- OXIDE / PLUGINS ----

# Set to true to install the Oxide mod framework on first boot.
# Required for any plugin support.
#ENABLE_OXIDE=false

# Override the Oxide download URL (e.g. to pin a specific release).
# Defaults to the latest release from the OxideMod GitHub.
#OXIDE_DOWNLOAD_URL=https://github.com/OxideMod/Oxide.Rust/releases/latest/download/Oxide.Rust-linux.zip

# Oxide plugins to install from uMod.org, one per line.
# Merged with mod-configs/plugins.txt — either source keeps a plugin installed.
#PLUGIN_LIST="TruePve
#ZoneManager
#ZoneManagerAutoZones"

# ---- UPDATE BEHAVIOUR ----

# Controls when RustDedicated is updated via SteamCMD on container start.
#   if-missing  - only install if the binary is not present (default, fast)
#   always      - run steamcmd update every boot (slower, keeps server current)
#RUST_UPDATE_MODE=if-missing

# ---- MONITORING ----

# Monitor RustDedicated and kill the container if the process stops,
# triggering a docker compose auto-restart.
uptime_monitoring=true

# ---- ADVANCED ----

# Path to a pre-installed steamcmd binary on the host.
# Leave unset to have the container download steamcmd automatically.
#STEAMCMD_PATH=
